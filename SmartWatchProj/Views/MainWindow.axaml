<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmartWatchProj.ViewModels"
        xmlns:models="using:SmartWatchProj.Models"
        xmlns:devices="using:SmartWatchProj.Models.Devices"
        xmlns:conv="using:SmartWatchProj.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="SmartWatchProj.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SmartWatchProj"
        MinWidth="1000" MinHeight="600"
        WindowState="FullScreen">

    <!-- Background -->
	<Window.Background>
		<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
			<GradientStop Offset="0" Color="#FF6D00" />
			<GradientStop Offset="1" Color="#FFCC40" />
		</LinearGradientBrush>
	</Window.Background>

	<!-- Resources -->
	<Window.Resources>
		<conv:RecommendationToBrushConverter x:Key="RecToBrush" />
	</Window.Resources>
	
	<!-- Styles (Р±РµР· РёР·РјРµРЅРµРЅРёР№) -->
	<Window.Styles>
		<Style Selector="Button">
			<Setter Property="Background" Value="#FF6D00" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="12,6" />
			<Setter Property="FontSize" Value="14" />
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.3" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#E64517" />
		</Style>

		<!-- ProgressBar: С„РёСЂРјРµРЅРЅС‹Р№ РѕСЂР°РЅР¶РµРІС‹Р№ (РєР°Рє РєРЅРѕРїРєРё) -->
		<Style Selector="ProgressBar">
			<Setter Property="Background" Value="#FFF3E0" />
			<Setter Property="Foreground" Value="#FF6D00" />
		</Style>

		<!-- РџРѕР»РѕСЃР° Р·Р°РїРѕР»РЅРµРЅРёСЏ (determinate) -->
		<Style Selector="ProgressBar /template/ Border#PART_Indicator">
			<Setter Property="Background" Value="#FF6D00" />
		</Style>
		<Style Selector="ProgressBar /template/ Rectangle#PART_Indicator">
			<Setter Property="Fill" Value="#FF6D00" />
		</Style>

		<!-- РџРѕР»РѕСЃР° "Р±РµРіСѓС‰Р°СЏ" (indeterminate) -->
		<Style Selector="ProgressBar /template/ Border#PART_IndeterminateIndicator">
			<Setter Property="Background" Value="#FF6D00" />
		</Style>
		<Style Selector="ProgressBar /template/ Rectangle#PART_IndeterminateIndicator">
			<Setter Property="Fill" Value="#FF6D00" />
		</Style>

		<!-- РЈР±РёСЂР°РµРј СЃРёРЅРёР№ С„РѕРєСѓСЃ (СЂР°РјРєСѓ СЃ СѓРіР»Р°РјРё) Сѓ СЌР»РµРјРµРЅС‚РѕРІ РёСЃС‚РѕСЂРёРё -->
		<Style Selector="ListBox.history ListBoxItem:focus">
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>

		<!-- РќР° РІСЃСЏРєРёР№ СЃР»СѓС‡Р°Р№: РµСЃР»Рё С‚РµРјР° СЂРёСЃСѓРµС‚ С„РѕРєСѓСЃ РІРЅСѓС‚СЂРё С€Р°Р±Р»РѕРЅР° -->
		<Style Selector="ListBox.history ListBoxItem:focus /template/ Border">
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>

		<Style Selector="ProgressBar">
			<!-- РџРµСЂРµРѕРїСЂРµРґРµР»СЏРµРј accent-РєРёСЃС‚Рё РўРћР›Р¬РљРћ РІРЅСѓС‚СЂРё ProgressBar -->
			<Style.Resources>
				<SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#FF6D00"/>
				<SolidColorBrush x:Key="SystemControlHighlightAccentBrush2" Color="#FF6D00"/>
				<SolidColorBrush x:Key="SystemControlHighlightAccentBrush3" Color="#FF6D00"/>
				<SolidColorBrush x:Key="SystemAccentColorBrush" Color="#FF6D00"/>
			</Style.Resources>

			<Setter Property="Background" Value="#FFF3E0" />
			<Setter Property="Foreground" Value="#FF6D00" />
		</Style>
	</Window.Styles>
	<Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

        <!-- Р—Р°РіРѕР»РѕРІРѕРє СЃ РёРєРѕРЅРєРѕР№ -->
		<StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
			<Image Source="/Assets/rosgaz-logo.png" Width="64" Height="64" Margin="0,0,10,0" />
			<TextBlock Text="Мониторинг здоровья сотрудников" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="Black" />
		</StackPanel>

		<!-- Р›РµРІР°СЏ РїР°РЅРµР»СЊ: Р’РІРѕРґ Рё СѓРїСЂР°РІР»РµРЅРёРµ (СЂРѕРІРЅР°СЏ РєРѕР»РѕРЅРєР° + СЃРѕРѕР±С‰РµРЅРёСЏ) -->
		<StackPanel Grid.Row="1" Grid.Column="0"
					Spacing="14"
					Margin="0,20,20,0"
					VerticalAlignment="Top"
					HorizontalAlignment="Center"
					Width="300">

			<TextBlock Text="Ввод ID карты"
					   FontSize="18"
					   FontWeight="SemiBold"
					   TextAlignment="Center"
					   HorizontalAlignment="Center"
					   Margin="0,0,0,6"/>

			<TextBox Text="{Binding CardId}"
					 Watermark="ID карты"
					 Width="260"
					 FontSize="14"
					 HorizontalAlignment="Center"/>

			<TextBox Watermark="ФИО сотрудника"
					 Text="{Binding NewEmployeeName}"
					 Width="260"
					 HorizontalAlignment="Center"/>

			<TextBox Watermark="CardId"
					 Text="{Binding NewCardId}"
					 Width="260"
					 HorizontalAlignment="Center"/>

			<Button Content="Добавить сотрудника"
					Command="{Binding AddEmployeeCommand}"
					Width="260"
					HorizontalAlignment="Center"
					HorizontalContentAlignment="Center"/>

			<Button Content="Симулировать пропуск"
					Command="{Binding SimulateCardReadCommand}"
					IsVisible="False"
					Width="260"
					HorizontalAlignment="Center"
					HorizontalContentAlignment="Center"/>

			<Button Content="Старт"
					Command="{Binding StartCommand}"
					IsEnabled="{Binding CanStartMeasurement}"
					Width="260"
					HorizontalAlignment="Center"
					HorizontalContentAlignment="Center"/>

			<ProgressBar IsIndeterminate="{Binding IsCollectingData}"
						 Height="18"
						 Width="260"
						 Margin="0,8,0,0"
						 HorizontalAlignment="Center"/>

			<!-- Р’Р•Р РҐРќРЇРЇ РїР°РЅРµР»СЊ: С‚РѕР»СЊРєРѕ РѕС€РёР±РєРё РѕС‚ РєРЅРѕРїРѕРє/РІРІРѕРґР° -->
			<Border IsVisible="{Binding IsTopInfoVisible}"
					Background="#FFFFFF"
					CornerRadius="14"
					BorderBrush="#22000000"
					BorderThickness="1"
					BoxShadow="0 8 20 0 #1A000000"
					Width="260"
					Margin="0,10,0,0">

				<Grid ColumnDefinitions="8,*">
					<Border Grid.Column="0"
							Background="{Binding TopInfoColor}"
							CornerRadius="14,0,0,14"/>
					<Border Grid.Column="1" Padding="12,10">
						<TextBlock Text="{Binding TopInfoMessage}"
								   Foreground="{Binding TopInfoColor}"
								   FontSize="13"
								   FontWeight="Bold"
								   TextWrapping="Wrap"/>
					</Border>
				</Grid>
			</Border>
				</StackPanel>

		<!-- РЎРѕРѕР±С‰РµРЅРёСЏ/РѕС€РёР±РєРё: РєРѕРјРїР°РєС‚РЅР°СЏ РєР°СЂС‚РѕС‡РєР° -->
				
		<Border Grid.Row="2" Grid.Column="0"
				Background="#FFFFFF"
				CornerRadius="14"
				Padding="0"
				BorderBrush="#22000000"
				BorderThickness="1"
				BoxShadow="0 10 30 0 #22000000"
				Margin="0,0,20,10"
				VerticalAlignment="Top">
			<Grid ColumnDefinitions="8,*">
				<Border Grid.Column="0"
						Background="{Binding ResultColor}"
						CornerRadius="14,0,0,14" />
				<Border Grid.Column="1" Padding="12,10">
					<StackPanel Spacing="6">
						<TextBlock Text="Панель информации"
								   FontSize="12"
								   FontWeight="SemiBold"
								   Opacity="0.7" />
						<ScrollViewer MaxHeight="90" VerticalScrollBarVisibility="Auto">
							<TextBlock Text="{Binding ResultMessage}"
									   Foreground="{Binding ResultColor}"
									   FontWeight="SemiBold"
									   FontSize="14"
									   TextWrapping="Wrap" />
						</ScrollViewer>
					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
				Background="#FFFFFF"
				CornerRadius="16"
				Padding="12"
				BorderBrush="#22000000"
				BorderThickness="1"
				BoxShadow="0 10 24 0 #22000000"
				Margin="0,0,0,12">

			<Expander IsExpanded="{Binding IsEquipmentPanelExpanded}">
				<Expander.Header>
					<Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
						<StackPanel Spacing="4">
							<TextBlock Text="Оборудование и настройки"
									   FontSize="16"
									   FontWeight="SemiBold"/>
							<TextBlock Text="{Binding EquipmentCompactSummary}"
									   Foreground="{Binding EquipmentSummaryColor}"
									   FontSize="12"
									   FontWeight="SemiBold"
									   TextWrapping="Wrap"/>
						</StackPanel>

						<Border Grid.Column="1"
								Background="#FFF3E0"
								CornerRadius="999"
								Padding="12,6"
								VerticalAlignment="Center">
							<TextBlock Text="Подготовка к запуску"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Foreground="#A64500"/>
						</Border>
					</Grid>
				</Expander.Header>

				<Grid Margin="0,16,0,0"
					  ColumnDefinitions="340,*"
					  ColumnSpacing="18"
					  MinHeight="0">
					<StackPanel Grid.Column="0" Spacing="10" VerticalAlignment="Top">
						<TextBlock Text="Подготовка к реальному запуску"
								   FontSize="16"
								   FontWeight="SemiBold"/>

						<TextBlock Text="Раздел раскрывается только при необходимости, поэтому основной экран остаётся компактным."
								   FontSize="12"
								   Opacity="0.75"
								   TextWrapping="Wrap"/>

						<TextBox Text="{Binding ManualEmployeeId}"
								 Watermark="EmployeeId (ручной ввод)"
								 MinHeight="36"/>

						<ComboBox ItemsSource="{Binding Employees}"
								  SelectedItem="{Binding SelectedEmployee}"
								  MinHeight="36">
							<ComboBox.ItemTemplate>
								<DataTemplate x:DataType="models:Employee">
									<TextBlock Text="{Binding Name, StringFormat='{}{0}'}"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

						<Button Content="Подтвердить сотрудника"
								Command="{Binding ConfirmEmployeeCommand}"
								HorizontalContentAlignment="Center"/>

						<Border Background="#FFF8E1"
								CornerRadius="12"
								Padding="10">
							<TextBlock Text="{Binding ConfirmedEmployeeDisplay}"
									   TextWrapping="Wrap"
									   FontWeight="SemiBold"/>
						</Border>

						<Grid ColumnDefinitions="*,*" ColumnSpacing="8">
							<Button Grid.Column="0"
									Content="Проверить оборудование"
									Command="{Binding CheckEquipmentCommand}"
									HorizontalContentAlignment="Center"/>
							<Button Grid.Column="1"
									Content="Сохранить настройки"
									Command="{Binding SaveDeviceSettingsCommand}"
									HorizontalContentAlignment="Center"/>
						</Grid>

						<Button Content="Тестовый прогон"
								Command="{Binding StartTestRunCommand}"
								IsEnabled="{Binding CanStartTestRun}"
								HorizontalContentAlignment="Center"/>

						<Border Background="#F5F5F5"
								CornerRadius="12"
								Padding="10">
							<StackPanel Spacing="4">
								<TextBlock Text="Сводка оборудования"
										   FontSize="13"
										   FontWeight="SemiBold"/>
								<TextBlock Text="{Binding EquipmentSummary}"
										   Foreground="{Binding EquipmentSummaryColor}"
										   FontWeight="Bold"
										   TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

						<TextBlock Text="{Binding DeviceConfigurationPath, StringFormat='Конфиг: {0}'}"
								   FontSize="10"
								   TextWrapping="Wrap"/>
						<TextBlock Text="{Binding DeviceLogPath, StringFormat='Лог: {0}'}"
								   FontSize="10"
								   TextWrapping="Wrap"/>
					</StackPanel>

					<Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10" MinHeight="0">
						<StackPanel Spacing="4">
							<TextBlock Text="Модули оборудования"
									   FontSize="15"
									   FontWeight="SemiBold"/>
							<TextBlock Text="Карточки устройств доступны по требованию и прокручиваются только внутри своей области."
									   FontSize="12"
									   Opacity="0.75"
									   TextWrapping="Wrap"/>
						</StackPanel>

						<ScrollViewer Grid.Row="1"
								  VerticalScrollBarVisibility="Auto"
								  HorizontalScrollBarVisibility="Disabled"
								  MaxHeight="320"
								  MinHeight="0">
							<ItemsControl ItemsSource="{Binding DeviceModules}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="devices:DeviceModuleState">
										<Border Background="#FAFAFA"
												CornerRadius="12"
												Padding="12"
												BorderBrush="#18000000"
												BorderThickness="1"
												Margin="0,0,0,10">
											<Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
												<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
													<TextBlock Text="{Binding DisplayName}"
															   FontWeight="SemiBold"
															   FontSize="14"
															   TextWrapping="Wrap"/>
													<Border Grid.Column="1"
															Background="{Binding StatusBrush}"
															CornerRadius="999"
															Padding="8,3">
														<TextBlock Text="{Binding StatusText}"
																   Foreground="White"
																   FontSize="11"
																   FontWeight="Bold"/>
													</Border>
												</Grid>

												<TextBlock Grid.Row="1"
														   Text="{Binding StatusDetails}"
														   FontSize="12"
														   TextWrapping="Wrap"/>

												<Grid Grid.Row="2" RowDefinitions="Auto,Auto" RowSpacing="8" MinWidth="0">
													<Grid ColumnDefinitions="Auto,180,*" ColumnSpacing="10" MinWidth="0">
														<CheckBox Content="Вкл"
																  IsChecked="{Binding IsEnabled}"
																  VerticalAlignment="Center"/>

														<StackPanel Grid.Column="1" Spacing="4">
															<TextBlock Text="Режим порта"
																	   FontSize="11"
																	   Opacity="0.75"/>
															<ComboBox ItemsSource="{Binding PortModes}"
																	  SelectedItem="{Binding PortMode}"
																	  MinHeight="34"
																	  MinWidth="160"/>
														</StackPanel>

														<StackPanel Grid.Column="2" Spacing="4" MinWidth="0">
															<TextBlock Text="COM"
																	   FontSize="11"
																	   Opacity="0.75"/>
															<TextBox Text="{Binding PortName}"
																	 Watermark="COM"
																	 IsEnabled="{Binding CanEditPortName}"
																	 MinHeight="34"/>
														</StackPanel>
													</Grid>

													<Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" MinWidth="0">
														<StackPanel Grid.Column="0" Spacing="4" MinWidth="0">
															<TextBlock Text="Baud rate"
																	   FontSize="11"
																	   Opacity="0.75"/>
															<TextBox Text="{Binding BaudRate}"
																	 Watermark="Baud rate"
																	 MinHeight="34"/>
														</StackPanel>

														<StackPanel Grid.Column="1" Spacing="4" MinWidth="0">
															<TextBlock Text="Timeout, ms"
																	   FontSize="11"
																	   Opacity="0.75"/>
															<TextBox Text="{Binding TimeoutMs}"
																	 Watermark="Timeout ms"
																	 MinHeight="34"/>
														</StackPanel>
													</Grid>
												</Grid>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</ScrollViewer>
					</Grid>
				</Grid>
			</Expander>
		</Border>

		<Border Grid.Row="1" Grid.Column="1"
				Background="#F2F2F2"
				CornerRadius="16"
				BorderBrush="{Binding VerdictColor, FallbackValue=#81C784}"
				BorderThickness="3"
				MaxWidth="560"
				MaxHeight="340"
				MinHeight="200"
				VerticalAlignment="Stretch"
				HorizontalAlignment="Stretch"
				Margin="0,10,0,10">

			<Image Source="{Binding CameraFrame}"
				   Stretch="Uniform" />
		</Border>


		<!-- РћРєРЅРѕ СЂРµРєРѕРјРµРЅРґР°С†РёР№: Р°РґР°РїС‚РёРІРЅРѕ -->
		<Border Grid.Row="2" Grid.Column="1"
				Background="White"
				CornerRadius="20"
				Padding="16"
				BorderBrush="{Binding VerdictColor, FallbackValue=#4CAF50}"
				BorderThickness="3"
				MaxWidth="560"
				MinHeight="110"
				VerticalAlignment="Top"
				HorizontalAlignment="Stretch"
				Margin="0,0,0,10">

			<!-- РµСЃР»Рё С‚РµРєСЃС‚ РґР»РёРЅРЅС‹Р№ вЂ” Р±СѓРґРµС‚ РїСЂРѕРєСЂСѓС‚РєР°, Рё Р±Р»РѕРє РЅРµ СЂР°Р·РґСѓРµС‚СЃСЏ -->
			<ScrollViewer MaxHeight="160">
				<TextBlock Text="{Binding HumanRecommendation}"
						   TextWrapping="Wrap"
						   FontSize="14"
						   Foreground="Black" />
			</ScrollViewer>
		</Border>




		<!-- РСЃС‚РѕСЂРёСЏ РёР·РјРµСЂРµРЅРёР№: Р¤РёРєСЃРёСЂРѕРІР°РЅРЅС‹Р№ СЂР°Р·РјРµСЂ (РЅРµ СЂР°СЃС€РёСЂСЏРµС‚СЃСЏ Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРё), РІРµСЂС… РІС‹СЂРѕРІРЅРµРЅ СЃ РєР°РјРµСЂРѕР№ -->
		<StackPanel Grid.Row="1" Grid.Column="2" Grid.RowSpan="2"
					Margin="20,0,0,0" VerticalAlignment="Top" MaxHeight="600">

			<TextBlock Text="История измерений" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />

			<Border Background="#F3F3F3" CornerRadius="16" Padding="12"
					BoxShadow="0 10 30 0 #22000000">
				<ScrollViewer MaxHeight="520">
					<ListBox Classes="history"
								ItemsSource="{Binding Measurements}"
								SelectionMode="Single"
								Focusable="False"
								Background="Transparent"
								BorderThickness="0">

						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="models:VitalMeasurement">
								<Border Background="White" CornerRadius="14" Padding="12"
										BoxShadow="0 6 16 0 #1A000000">

									<Grid ColumnDefinitions="6,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10">

										<!-- РџРѕР»РѕСЃРєР° СЃС‚Р°С‚СѓСЃР° СЃР»РµРІР° -->
										<Border Grid.RowSpan="2" Grid.Column="0"
												Background="{Binding Recommendation, Converter={StaticResource RecToBrush}}"
												CornerRadius="10,0,0,10"/>

										<TextBlock Grid.Column="1"
												   Text="{Binding Timestamp, StringFormat='Время: {0:dd.MM.yyyy HH:mm}'}"
												   FontSize="13" FontWeight="SemiBold" />

										<TextBlock Grid.Row="1" Grid.Column="1"
												   Text="{Binding EmployeeId, StringFormat='ID: {0}'}"
												   FontSize="12" Opacity="0.75" />

										<!-- Р‘РµР№РґР¶ СЃРїСЂР°РІР° -->
										<Border Grid.RowSpan="2" Grid.Column="2"
												Background="{Binding Recommendation, Converter={StaticResource RecToBrush}}"
												CornerRadius="999" Padding="10,4"
												VerticalAlignment="Center" MaxWidth="240">
											<TextBlock Text="{Binding Recommendation}"
													   Foreground="White"
													   FontSize="12" FontWeight="SemiBold"
													   TextTrimming="CharacterEllipsis" />
										</Border>

									</Grid>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>

					</ListBox>
				</ScrollViewer>
			</Border>
						</StackPanel>

		<!-- РќРёР¶РЅСЏСЏ Р·РѕРЅР°: РїРѕРґРїРёСЃСЊ + РїР»РёС‚РєРё РїР°СЂР°РјРµС‚СЂРѕРІ -->
		<StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
					HorizontalAlignment="Center"
					VerticalAlignment="Bottom"
					Margin="0,20,0,20"
					Spacing="10"
					MaxWidth="1200">

			<!-- РќР°РґРїРёСЃСЊ РЅР°Рґ РїР»РёС‚РєР°РјРё -->
			<TextBlock Text="Плитки с данными присутствуют только в первой версии программы для наглядной симуляции работы"
					   FontSize="13"
					   FontWeight="SemiBold"
					   Foreground="#000000"
					   TextAlignment="Center"
					   TextWrapping="Wrap"
					   MaxWidth="900"
					   Margin="0,0,0,6" />

			<!-- РџР»РёС‚РєРё РїР°СЂР°РјРµС‚СЂРѕРІ: Р’ Р»РёРЅРёСЋ РіРѕСЂРёР·РѕРЅС‚Р°Р»СЊРЅРѕ РІ РЅРёР¶РЅРµР№ С‡Р°СЃС‚Рё (РѕРґРёРЅ СЂСЏРґ, 8 РєРѕР»РѕРЅРѕРє) -->
			<Grid ColumnDefinitions="*,*,*,*,*,*,*,*"
				  RowDefinitions="Auto"
				  HorizontalAlignment="Center"
				  VerticalAlignment="Bottom"
				  MaxWidth="1200">

				<!-- Р СЏРґ 1: 8 РїР»РёС‚РѕРє РІ Р»РёРЅРёСЋ (СѓР±СЂР°РЅР° С…РѕР»РµСЃС‚РµСЂРёРЅ) -->
				<Border Grid.Column="0" Background="#E3F2FD" CornerRadius="16" Padding="24" Margin="4">
					<TextBlock Text="{Binding LastHeartRate, StringFormat='ЧСС&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#1565C0" LineHeight="24"/>
				</Border>

				<Border Grid.Column="1" Background="#FFF3E0" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastSaturation, StringFormat='Сатурация&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#EF6C00" LineHeight="24"/>
				</Border>

				<Border Grid.Column="2" Background="#E8F5E9" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastBloodPressure, StringFormat='Давление&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#2E7D32" LineHeight="24"/>
				</Border>

				<Border Grid.Column="3" Background="#FFFDE7" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastTemperature, StringFormat='Температура&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#F57F17" LineHeight="24"/>
				</Border>

				<Border Grid.Column="4" Background="#E1F5FE" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastGlucose, StringFormat='Глюкоза&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#0277BD" LineHeight="24"/>
				</Border>

				<Border Grid.Column="5" Background="#FFEBEE" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastAlcoholLevel, StringFormat='Алкоголь&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#C62828" LineHeight="24"/>
				</Border>

				<Border Grid.Column="6" Background="#E8EAF6" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastActivityLevel, StringFormat='Активность&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#303F9F" LineHeight="24"/>
				</Border>

				<Border Grid.Column="7" Background="#F1F8E9" CornerRadius="16" Padding="24,18,24,18" Margin="4">
					<TextBlock Text="{Binding LastRecommendation, StringFormat='Вердикт&#10;{0}'}"
							   FontSize="12" TextWrapping="Wrap" MaxWidth="120"
							   FontWeight="Bold" TextAlignment="Center"
							   Foreground="#33691E" LineHeight="24"/>
				</Border>

			</Grid>
						</StackPanel>

		<!-- РЎС‚Р°С‚СѓСЃРЅР°СЏ РїР°РЅРµР»СЊ: Р’РЅРёР·Сѓ РїРѕ С†РµРЅС‚СЂСѓ -->
        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='Дата/время: {0:dd.MM.yyyy HH:mm}'}" FontSize="14" Margin="0,0,20,0" />
            <TextBlock x:Name="StatusText" Text="Статус: Камера и YOLO готовы" FontSize="14" Foreground="#388E3C" />
        </StackPanel>


		<Button Grid.Row="5" Grid.Column="0" Content="Синхронизировать с сайтом" Command="{Binding SyncDataCommand}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10" />
		
        <!-- РљРЅРѕРїРєР° РІС‹С…РѕРґР°: Р’РЅРёР·Сѓ СЃРїСЂР°РІР°, РЅРµ РЅР°РµР·Р¶Р°РµС‚ -->
		<Button Grid.Row="5" Grid.Column="2" Content="Завершить и выйти" Command="{Binding FinishAndExitCommand}" Width="200" HorizontalContentAlignment="Center" Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Padding="16,8" />

	
		<Border x:Name="Overlay"
        Grid.Row="0" Grid.Column="0"
        Grid.RowSpan="10" Grid.ColumnSpan="10"
        Background="#80000000"
        IsVisible="{Binding IsOverlayVisible}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        IsHitTestVisible="True">
			
			

			<StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

				<!-- ===================== CAPTCHA (С‚РІРѕСЏ СЃС‚Р°СЂР°СЏ Р»РѕРіРёРєР°, С‚РѕР»СЊРєРѕ UI СЃС‚Р°Р±РёР»РёР·РёСЂСѓРµРј) ===================== -->
				<Viewbox IsVisible="{Binding IsCaptchaVisible}"
						 Stretch="Uniform"
						 StretchDirection="DownOnly"
						 HorizontalAlignment="Center"
						 VerticalAlignment="Center"
						 Margin="20">

					<Border Background="White"
							CornerRadius="8"
							Padding="20"
							Width="450"
							BorderBrush="#22000000"
							BorderThickness="1"
							BoxShadow="0 10 30 0 #22000000">

						<StackPanel Spacing="10">

							<!-- Р“Р»Р°РІРЅРѕРµ: СЏРІРЅС‹Р№ С‡С‘СЂРЅС‹Р№ С†РІРµС‚, С‡С‚РѕР±С‹ С‚РµРєСЃС‚ РЅРµ РёСЃС‡РµР·Р°Р» РЅР° Win11/С‚РµРјРЅРѕР№ С‚РµРјРµ -->
							<TextBlock Text="{Binding CaptchaPrompt}"
									   FontSize="18"
									   FontWeight="Bold"
									   TextAlignment="Center"
									   TextWrapping="Wrap"
									   Foreground="#000000"/>

							<TextBlock Text="{Binding SelectedCount, StringFormat='Выбрано: {0} элементов'}"
									   FontSize="14"
									   TextAlignment="Center"
									   TextWrapping="Wrap"
									   Foreground="#1A1A1A"/>

							<Canvas Height="200" Margin="10">
								<Button Canvas.Left="{Binding CaptchaLefts[0]}" Canvas.Top="{Binding CaptchaTops[0]}"
										Content="{Binding CaptchaItems[0]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="0"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[0]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[1]}" Canvas.Top="{Binding CaptchaTops[1]}"
										Content="{Binding CaptchaItems[1]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="1"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[1]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[2]}" Canvas.Top="{Binding CaptchaTops[2]}"
										Content="{Binding CaptchaItems[2]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="2"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[2]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[3]}" Canvas.Top="{Binding CaptchaTops[3]}"
										Content="{Binding CaptchaItems[3]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="3"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[3]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[4]}" Canvas.Top="{Binding CaptchaTops[4]}"
										Content="{Binding CaptchaItems[4]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="4"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[4]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[5]}" Canvas.Top="{Binding CaptchaTops[5]}"
										Content="{Binding CaptchaItems[5]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="5"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[5]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[6]}" Canvas.Top="{Binding CaptchaTops[6]}"
										Content="{Binding CaptchaItems[6]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="6"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[6]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[7]}" Canvas.Top="{Binding CaptchaTops[7]}"
										Content="{Binding CaptchaItems[7]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="7"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[7]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
								<Button Canvas.Left="{Binding CaptchaLefts[8]}" Canvas.Top="{Binding CaptchaTops[8]}"
										Content="{Binding CaptchaItems[8]}"
										Command="{Binding CaptchaClickCommand}" CommandParameter="8"
										Width="50" Height="50" FontSize="20"
										Background="{Binding CaptchaBackgrounds[8]}" Foreground="Black"
										BorderBrush="Gray" BorderThickness="1" CornerRadius="25" />
							</Canvas>

							<Button Content="Принять"
									Command="{Binding CheckCaptchaCommand}"
									HorizontalAlignment="Center"
									Width="120"/>

							<TextBlock Text="{Binding CaptchaMessage}"
									   FontSize="14"
									   TextAlignment="Center"
									   TextWrapping="Wrap"
									   Foreground="#C62828"/>
						</StackPanel>
					</Border>
				</Viewbox>


				<!-- ===================== РџР°РЅРµР»СЊ РёРЅСЃС‚СЂСѓРєС†РёР№ (РєР°Рє Сѓ С‚РµР±СЏ, РїСЂРѕСЃС‚Рѕ С†РµРЅС‚СЂРёСЂСѓРµРј) ===================== -->
				<Border IsVisible="{Binding !IsCaptchaVisible}"
						Background="White"
						CornerRadius="8"
						Padding="20"
						Margin="20"
						Width="300"
						HorizontalAlignment="Center"
						VerticalAlignment="Center">

					<StackPanel Spacing="10">
						<TextBlock Text="{Binding CurrentInstruction}"
								   FontSize="16"
								   FontWeight="Bold"
								   TextAlignment="Center"
								   TextWrapping="Wrap"
								   Foreground="#000000"/>

						<ProgressBar Value="{Binding ProgressValue}"
									 Minimum="0"
									 Maximum="100"
									 Height="20"
									 Margin="10">
							<ProgressBar.Foreground>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
									<GradientStop Color="#FF6D00" Offset="0"/>
									<GradientStop Color="#FFCC40" Offset="1"/>
								</LinearGradientBrush>
							</ProgressBar.Foreground>
						</ProgressBar>
					</StackPanel>
				</Border>


			</StackPanel>
		</Border>
	
	
	
	</Grid>
</Window>

